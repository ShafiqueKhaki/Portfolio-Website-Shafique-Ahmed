# Database
DATABASE_URL=postgresql+psycopg://postgres:yourpassword@localhost:5432/portfolio_db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin seed (used by seed.py)
ADMIN_NAME=Shafique Ahmed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
# Set to "true" to force-update admin credentials even if admin already exists
ADMIN_FORCE_UPDATE=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key
CONTACT_NOTIFICATION_EMAIL=shafique@example.com

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# App
APP_ENV=development
